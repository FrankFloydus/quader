{
  "version": 6,
  "configurePresets": [
    {
      "name": "qt-mingw-debug",
      "displayName": "Qt MinGW Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/qt-mingw-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "C:/Qt/6.11.1/mingw_64",
        "CMAKE_C_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/g++.exe"
      },
      "environment": {
        "PATH": "C:/Qt/Tools/mingw1310_64/bin;C:/Qt/6.11.1/mingw_64/bin;$penv{PATH}"
      }
    },
    {
      "name": "qt-mingw-release",
      "displayName": "Qt MinGW Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/qt-mingw-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_PREFIX_PATH": "C:/Qt/6.11.1/mingw_64",
        "CMAKE_C_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/g++.exe"
      },
      "environment": {
        "PATH": "C:/Qt/Tools/mingw1310_64/bin;C:/Qt/6.11.1/mingw_64/bin;$penv{PATH}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qt-mingw-debug",
      "configurePreset": "qt-mingw-debug"
    },
    {
      "name": "qt-mingw-release",
      "configurePreset": "qt-mingw-release"
    }
  ],
  "testPresets": [
    {
      "name": "qt-mingw-debug",
      "configurePreset": "qt-mingw-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "qt-mingw-release",
      "configurePreset": "qt-mingw-release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    }
  ]
