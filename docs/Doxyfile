# Quader Doxygen configuration.
#
# Generate with:
#   doxygen docs/Doxyfile

PROJECT_NAME           = "Quader"
PROJECT_BRIEF          = "C++20 Qt Widgets polygon modeling application"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = docs/mainpage.md

INPUT                  = docs/mainpage.md \
                         src \
                         tests \
                         benchmarks
RECURSIVE              = YES
FILE_PATTERNS          = *.h \
                         *.hpp \
                         *.hh \
                         *.cpp \
                         *.cc \
                         *.cxx \
                         *.ipp \
                         *.inl
EXCLUDE_PATTERNS       = */build/* \
                         */build-*/* \
                         */cmake-build-*/* \
                         */out/*

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
SIP_SUPPORT            = NO
IDL_PROPERTY_SUPPORT   = NO

JAVADOC_AUTOBRIEF      = NO
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_MENUS     = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome-css/doxygen-awesome.css \
                         docs/quader-doxygen.css
MERMAID_RENDER_MODE    = CLI

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           = docs/doxygen_warnings.log

QUIET                  = NO
